# Sanity – frontend (Vite)
# Get Project ID from https://sanity.io/manage
VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production
# Optional: defaults to 2025-01-01
# VITE_SANITY_API_VERSION=2025-01-01
# Optional: use CDN (true) or live API (false)
# VITE_SANITY_USE_CDN=true

# Form submissions POST to /api/send-email (Vercel serverless at repo root: api/send-email.ts).
# In Vercel: set GMAIL_USER, GMAIL_APP_PASSWORD, and EMAIL_TO (optional; defaults to GMAIL_USER).
# If the site is static-only elsewhere, set the API origin:
# VITE_FORM_API_BASE_URL=https://your-deployment.vercel.app
# Optional CORS on the function: FORM_ALLOWED_ORIGINS=https://your-frontend.com,https://www.your-frontend.com

# Local Vite dev has no /api unless you use `vercel dev` from the repo root. To test forms in `npm run dev`:
# VITE_MOCK_FORM_SUBMIT=true
