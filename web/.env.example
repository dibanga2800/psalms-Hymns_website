# Sanity – frontend (Vite)
# Get Project ID from https://sanity.io/manage
VITE_SANITY_PROJECT_ID=your_project_id
VITE_SANITY_DATASET=production
# Optional: defaults to 2025-01-01
# VITE_SANITY_API_VERSION=2025-01-01
# Optional: use CDN (true) or live API (false)
# VITE_SANITY_USE_CDN=true

# Form submission API (optional – defaults to /api/send-email on Vercel)
# Override if using a different backend
# VITE_CONTACT_API_URL=/api/send-email

# --- Vercel Environment Variables (set in Vercel dashboard) ---
# GMAIL_USER=rccgpsalmshymns@gmail.com
# GMAIL_APP_PASSWORD=<16-char app password from Google>
# EMAIL_TO=rccgpsalmshymns@gmail.com
